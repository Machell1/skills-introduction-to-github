# FNID Portal Configuration
# Copy this to .env and update values for your environment.

# REQUIRED in production - generate with: python -c "import secrets; print(secrets.token_hex(32))"
FNID_SECRET_KEY=change-me-to-a-random-secret

# Environment: development | production | testing
FLASK_ENV=development

# Database path (default: src/fnid_portal/data/fnid.db)
# FNID_DB_PATH=/var/lib/fnid/fnid.db

# Upload directory (default: src/fnid_portal/data/uploads)
# FNID_UPLOAD_DIR=/var/lib/fnid/uploads

# Export directory (default: src/fnid_portal/data/exports)
# FNID_EXPORT_DIR=/var/lib/fnid/exports
