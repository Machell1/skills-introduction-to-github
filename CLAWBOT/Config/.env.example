# CLAWBOT Environment Configuration
# ====================================
# DO NOT commit actual credentials to version control!
# Copy this file to .env and fill in your values.
# The credential_manager.py script handles this automatically.
#
# Your actual credentials are stored encrypted in .env.encrypted

# Deriv MT5 Server (do not put password here)
MT5_SERVER=Deriv-Server
MT5_LOGIN=your_login_id
MT5_BROKER=Deriv

# Trading Settings Override (optional)
# RISK_PER_TRADE=1.5
# MAX_DAILY_LOSS=3.0
# BOT_MODE=Backtest
