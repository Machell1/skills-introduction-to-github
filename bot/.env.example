# === Deal Alert Bot Configuration ===

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel ID (e.g., @yourchannel or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_here

# === Affiliate Tags ===
# Sign up for each store's affiliate program to earn commissions.

# Amazon Associates (affiliate-program.amazon.com)
AMAZON_AFFILIATE_TAG=your-tag-20

# Walmart Affiliate (Impact Radius - impact.com)
# Your Impact Radius campaign ID for Walmart
WALMART_AFFILIATE_TAG=

# Target Affiliate (Impact Radius - impact.com)
# Your Impact Radius campaign ID for Target
TARGET_AFFILIATE_TAG=

# Best Buy Affiliate (Impact Radius - impact.com)
BESTBUY_AFFILIATE_TAG=

# eBay Partner Network (partnernetwork.ebay.com)
# Your eBay campaign ID
EBAY_AFFILIATE_CAMPAIGN_ID=

# === Lifestyle & Travel Affiliate Tags ===

# Groupon (via Impact Radius - impact.com)
# Covers birthday gifts, party deals, wedding packages, baby shower gifts
GROUPON_AFFILIATE_TAG=

# Skyscanner (via Impact Radius - impact.com)
# Flight deal commissions
SKYSCANNER_AFFILIATE_TAG=

# Expedia (via CJ Affiliate - cj.com or Partnerize)
# Holiday/vacation package commissions
EXPEDIA_AFFILIATE_TAG=

# === X (Twitter) API ===
# Get these from developer.x.com (see README for setup steps)

# API Key and Secret (from your X app)
X_API_KEY=
X_API_SECRET=

# Access Token and Secret (with Read and Write permissions)
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Enable auto-posting deals to X (set to true to activate)
X_POST_ENABLED=false

# === Telegram Bot Admin ===

# Comma-separated Telegram user IDs allowed to control the bot
# Get your ID by messaging @userinfobot on Telegram
ADMIN_USER_IDS=

# === Database ===

# Database file path (set to /data/deals.db on Railway with a volume mount)
# Leave empty to use default (deals.db in the bot directory)
DB_PATH=

# === Bot Settings ===

# How often to check tracked product prices (in minutes)
CHECK_INTERVAL_MINUTES=60

# Minimum price drop percentage to trigger an alert
MIN_DROP_PERCENT=15

# Minimum price drop in dollars to trigger an alert
MIN_DROP_DOLLARS=5
