# === Deal Alert Bot Configuration ===

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel ID (e.g., @yourchannel or -1001234567890)
# To get the ID: add your bot to the channel, send a message,
# then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHANNEL_ID=@your_channel_here

# Amazon Affiliate Tag (sign up at affiliate-program.amazon.com)
AMAZON_AFFILIATE_TAG=your-tag-20

# How often to check prices (in minutes)
CHECK_INTERVAL_MINUTES=60

# Minimum price drop percentage to trigger an alert
MIN_DROP_PERCENT=15

# Minimum price drop in dollars to trigger an alert
MIN_DROP_DOLLARS=5
